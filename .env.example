# LLM Deployment System Configuration

# Server port (use 80 for balena tunnel access)
PORT=80

# State file location (on CM4, this should be /collect_data/state.json)
STATE_FILE_PATH=/collect_data/state.json

# Collect data volume path (on CM4, this is where JSON outputs are written)
COLLECT_DATA_PATH=/collect_data

# Docker socket path (for log analysis)
# On most systems this is /var/run/docker.sock
DOCKER_SOCKET=/var/run/docker.sock

# Log check interval in milliseconds (default: 1 hour)
LOG_CHECK_INTERVAL=3600000

# Data validation window in milliseconds (default: 10 minutes)
VALIDATION_WINDOW=600000

# Node environment
NODE_ENV=production
