# LLM Deployment System Configuration

# ============================================
# SERVER CONFIGURATION
# ============================================
# Server port (use 80 for balena tunnel access)
PORT=80

# Node environment (production / development)
NODE_ENV=production

EQUINOX_MODE=configure
# Set to 'monitor' when running in production (docker-compose.prod.yml)
# Switches dashboard from configuration to chat/monitoring mode

# ============================================
# DATA PATHS
# ============================================
# State file location (on CM4, use /collect_data/state.json)
STATE_FILE_PATH=/collect_data/state.json

# Collect data volume path (where JSON outputs are written)
COLLECT_DATA_PATH=/collect_data

# Docker socket path (for container polling)
DOCKER_SOCKET=/var/run/docker.sock

# ============================================
# SCHEDULER / LOG ANALYSIS
# ============================================
# Log check interval in milliseconds (default: 1 hour = 3600000)
LOG_CHECK_INTERVAL=3600000

# Data validation window in milliseconds (default: 10 minutes = 600000)
VALIDATION_WINDOW=600000

# ============================================
# PHASE B: MONITORING SERVICE
# ============================================
# Monitoring interval in seconds (default: 300 = 5 minutes)
MONITORING_INTERVAL=300

# ============================================
# PHASE B: AWS IOT CORE (Optional)
# ============================================
# Enable IoT Core publishing (true/false)
IOT_PUBLISH_ENABLED=false

# IoT Core endpoint URL (from AWS IoT console)
AWSENDPOINT=

# Device thing name in AWS IoT
THINGNAME=

# Certificate and key filenames
CERT_NAME=device.crt
KEY_NAME=private.key
CA_1_NAME=ca.crt

# Certificate contents (PEM format)
CERT=
KEY=
CA_1=

# Device identifiers
SITE=
EDGE_ID=
BALENA_DEVICE_UUID=

# IoT Core topic base (device UUID appended automatically)
IOT_TOPIC=operate/device_reports

# ============================================
# BALENA / CLOUD DEPLOYMENT
# ============================================
# Balena API token (for deployment features)
BALENA_API_TOKEN=

# Cloud API URL (for deployment)
USE_CLOUD=true
CLOUD_API_URL=https://2x2uel6e80.execute-api.us-east-2.amazonaws.com/prod/deploy
